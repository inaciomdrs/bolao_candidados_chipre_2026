# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Bolao
PORT=3000
SECRET_KEY=change-me-to-a-32-byte-hex-string

# Database (SQLite for dev, PostgreSQL URL for prod)
DATABASE_URL="file:./dev.db"

# Mail (optional, app-controlled SMTP server only)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Security
TIME_ZONE=America/Sao_Paulo
LANGUAGE_CODE=pt-BR

# TOTP
TOTP_ISSUER=Bolao-2026
